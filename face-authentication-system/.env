# Face Authentication System - environment configuration
API_HOST=0.0.0.0
API_PORT=8000

# Cosine-distance threshold for accepting a face match (lower = stricter)
MATCH_DISTANCE_THRESHOLD=0.35

# Storage paths (relative to project root, override for custom deployments)
SQLITE_DB_PATH=backend/users.db
CHROMA_DB_PATH=vector_db/chroma_storage
REGISTERED_FACES_DIR=registered_faces
